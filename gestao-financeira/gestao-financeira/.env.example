# URL base da API gestao-financeira-api.
#
# Emulador Android (default): http://10.0.2.2:3000
# Device fisico Android: http://IP_DA_SUA_MAQUINA:3000  (descubra com `ipconfig`)
# iOS Simulator: http://localhost:3000
# Web (expo start --web): http://localhost:3000
#
# Para usar, copie este arquivo para `.env` na raiz de gestao-financeira/:
#   cp .env.example .env
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
